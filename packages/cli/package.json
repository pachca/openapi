{
  "name": "@pachca/cli",
  "version": "0.0.0",
  "description": "Official CLI for Pachca API",
  "type": "module",
  "bin": {
    "pachca": "./bin/run.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "bin",
    "dist",
    "oclif.manifest.json"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsx scripts/generate-cli.ts && tsc && oclif manifest",
    "dev": "node --import tsx bin/dev.js",
    "typecheck": "tsc --noEmit",
    "test": "tsc && vitest run",
    "generate-cli": "tsx scripts/generate-cli.ts"
  },
  "oclif": {
    "bin": "pachca",
    "dirname": "pachca",
    "commands": {
      "strategy": "pattern",
      "target": "./dist/commands"
    },
    "hooks": {
      "init": "./dist/hooks/init",
      "command_not_found": "./dist/hooks/command-not-found",
      "postrun": "./dist/hooks/postrun"
    },
    "plugins": [
      "@oclif/plugin-autocomplete"
    ],
    "topicSeparator": " "
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "@oclif/core": "^4.2.8",
    "@oclif/plugin-autocomplete": "^3.2.14",
    "ansis": "^3.17.0",
    "semver": "^7.7.1",
    "smol-toml": "^1.3.1",
    "string-width": "^8.2.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@oclif/test": "^4.1.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.14.0",
    "@types/semver": "^7.5.8",
    "js-yaml": "^4.1.0",
    "oclif": "^4.17.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pachca/openapi",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
