    "output": null
  },
  "listEvents": {
    "usage": "params = ListEventsParams(\n    is_active=True,\n    scopes=[OAuthScope.CHATS_READ],\n    filter=EventFilter()\n)\nawait client.events.list_events(params=params)",
    "output": "ListEventsResponse(data: list[Event])",
    "imports": [
      "EventFilter",
      "ListEventsParams",
      "OAuthScope"
    ]
  },
  "publishEvent": {
    "usage": "await client.events.publish_event(id=123, scope=OAuthScope.CHATS_READ)",
    "output": "Event(id: int, type: EventType)",
    "imports": [
      "OAuthScope"
    ]
  },
  "createUpload": {
    "usage": "request = UploadRequest(file=b\"\", content_disposition=\"example\")\nawait client.uploads.create_upload(request=request)",
    "output": null,
    "imports": [
