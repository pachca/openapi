<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <LangVersion>12</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>Pachca.Sdk</RootNamespace>

    <!-- NuGet package metadata -->
    <PackageId>Pachca.Sdk</PackageId>
    <Version>0.0.0</Version>
    <Authors>Pachca</Authors>
    <Description>Official Pachca API SDK for .NET</Description>
    <PackageProjectUrl>https://github.com/pachca/openapi</PackageProjectUrl>
    <RepositoryUrl>https://github.com/pachca/openapi</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>pachca;api;sdk;messenger;chat</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>

    <!-- Build settings -->
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>CS1591</NoWarn>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
