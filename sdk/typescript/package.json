    "generate": "bun scripts/strip-operations.ts && openapi-ts && bun generate-client.ts",
    "build": "tsc"
  },
  "dependencies": {},
  "devDependencies": {
    "@pachca/spec": "workspace:*",
    "@hey-api/openapi-ts": "^0.93.0",
    "yaml": "^2.7.0",
    "typescript": "^5.0.0"
