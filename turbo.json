{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "generate": {
      "dependsOn": ["setup", "^generate"],
      "inputs": [
        "typespec.tsp",
        "tspconfig.yaml",
        "../../packages/spec/openapi.yaml",
        "../../packages/generator/src/**",
        "../../packages/generator/bin/**"
      ],
      "outputs": ["openapi.yaml", "generated/**", "src/generated/**"],
      "cache": true
    },
    "setup": {
      "cache": false
    },
    "generate-llms": {
      "dependsOn": ["@pachca/spec#generate"],
      "inputs": ["scripts/generate-llms.ts", "scripts/skills/**", "lib/**", "content/**"],
      "outputs": ["public/llms.txt", "public/llms-full.txt", "public/skill.md", "public/index.md", "public/guides/**", "public/**/*.md", "public/.well-known/**", "public/pachca.postman_collection.json"],
      "cache": true
    },
    "generate-cli": {
      "dependsOn": ["@pachca/spec#generate"],
      "inputs": [
        "../../packages/spec/openapi.yaml",
        "scripts/generate-cli.ts",
        "../../apps/docs/lib/openapi/mapper.ts",
        "../../packages/spec/workflows.ts",
        "../../apps/docs/scripts/skills/config.ts"
      ],
      "outputs": ["src/commands/*/*.ts", "!src/commands/auth/*.ts", "!src/commands/config/*.ts", "src/data/*.json", "!src/data/changelog.json", "README.md"],
      "cache": true
    },
    "overlay:apply": {
      "dependsOn": ["@pachca/spec#generate"],
      "inputs": ["overlay.en.yaml", "openapi.yaml", "scripts/apply-overlay.ts"],
      "outputs": ["openapi.en.yaml"],
      "cache": true
    },
    "overlay:validate": {
      "dependsOn": ["@pachca/spec#generate", "@pachca/spec#overlay:apply"],
      "inputs": ["overlay.en.yaml", "openapi.yaml", "scripts/validate-overlay.ts"],
      "cache": true
    },
    "generate-n8n": {
      "dependsOn": ["^build", "@pachca/spec#generate", "@pachca/spec#overlay:apply"],
      "inputs": [
        "../../packages/spec/openapi.yaml",
        "../../packages/spec/openapi.en.yaml",
        "../../packages/spec/workflows.ts",
        "../../packages/spec/examples.ts",
        "../../packages/openapi-parser/src/**",
        "../../packages/generator/src/naming.ts",
        "../../apps/docs/lib/openapi/mapper.ts",
        "../../apps/docs/lib/openapi/example-generator.ts",
        "../../apps/docs/scripts/skills/config.ts",
        "scripts/**"
      ],
      "outputs": ["nodes/**/*.ts", "credentials/**/*.ts"],
      "cache": true
    },
    "build": {
      "dependsOn": ["^build", "generate", "overlay:apply", "generate-llms", "generate-cli", "generate-n8n"],
      "outputs": [".next/**", "!.next/cache/**", ".build/**", "dist/**", "oclif.manifest.json", "generated/bin/**", "generated/obj/**"],
      "cache": true
    },
    "dev": {
      "dependsOn": ["@pachca/spec#generate", "generate-llms"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "cache": true
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "knip": {
      "cache": true
    },
    "format:check": {
      "cache": true
    },
    "check": {
      "dependsOn": ["lint", "typecheck", "knip", "format:check", "test", "@pachca/spec#overlay:validate"],
      "cache": false
    },
    "check-urls": {
      "dependsOn": ["@pachca/spec#generate"],
      "cache": true
    },
    "update-snapshots": {
      "inputs": ["src/**", "tests/**/fixture.yaml"],
      "outputs": ["tests/**/snapshots/**"],
      "cache": false
    },
    "test": {
      "dependsOn": ["^build", "generate-cli", "generate-n8n"],
      "inputs": ["src/**", "tests/**"],
      "cache": true
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    }
  }
}
